# 3. Workspace Binding (Strategy A)
# Set this to the absolute path of the project folder you want the agent to edit.
# Example: /Users/choi/Desktop/workspace/NovelAIne
TARGET_WORKSPACE_PATH="/Users/choi/Desktop/workspace/NovelAIne"
