# Environment Variables for the Agent Backend

# 1. API Keys for LLMs
OPENROUTER_API_KEY=""
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# 2. Database
SUPABASE_URL=""
